generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Usuarios / Auth ──────────────────────────────────────────────────────────

enum Rol {
  reciclador_oficio
  operador_eca
  admin_asociacion
}

model Usuario {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  nombre      String
  rol         Rol
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reciclador  Reciclador?
  pqrsCreadas PQR[]     @relation("PQRSolicitante")
  pqrsAtendidas PQR[]   @relation("PQROperador")

  @@map("usuarios")
}

// ─── Recicladores ─────────────────────────────────────────────────────────────

enum EstadoReciclador {
  Activa
  Inactivo
}

model Reciclador {
  id            Int              @id @default(autoincrement())
  codigo        String           @unique  // e.g. "ID-0042"
  usuarioId     Int?             @unique
  usuario       Usuario?         @relation(fields: [usuarioId], references: [id])
  nombre        String
  documento     String?          @unique
  telefono      String?
  email         String?
  color          String           @default("#4caf7d")
  tipoTransporte String?
  estado         EstadoReciclador @default(Activa)
  rutaId        Int?
  ruta          Ruta?            @relation(fields: [rutaId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  pesajes       Pesaje[]

  @@map("recicladores")
}

// ─── Rutas ────────────────────────────────────────────────────────────────────

enum EstadoRuta {
  Activa
  Parcial
  Inactiva
}

model Ruta {
  id            Int        @id @default(autoincrement())
  numero        String     @unique  // e.g. "R-01"
  nombre        String
  descripcion   String?
  barrios       String[]   // lista de nombres de barrios
  estado        EstadoRuta @default(Activa)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  recicladores  Reciclador[]
  pesajes       Pesaje[]

  @@map("rutas")
}

// ─── Materiales ───────────────────────────────────────────────────────────────

enum TendenciaMaterial {
  subida
  bajada
  estable
}

model Material {
  id            Int               @id @default(autoincrement())
  nombre        String            @unique
  codigo        String            @unique  // e.g. "CAR-01"
  icono         String            @default("♻️")
  unidad        String            @default("kg")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  precios       PrecioMaterial[]
  pesajeMateriales PesajeMaterial[]
  compradores   Comprador[]

  @@map("materiales")
}

model PrecioMaterial {
  id          Int               @id @default(autoincrement())
  materialId  Int
  material    Material          @relation(fields: [materialId], references: [id])
  precio      Decimal           @db.Decimal(10, 2)  // COP por kg
  tendencia   TendenciaMaterial @default(estable)
  vigenciaDesde DateTime        @default(now())
  vigenciaHasta DateTime?
  operadorId  Int?
  createdAt   DateTime          @default(now())

  @@map("precios_material")
}

model Comprador {
  id          Int      @id @default(autoincrement())
  empresa     String
  materialId  Int
  material    Material @relation(fields: [materialId], references: [id])
  precio      Decimal  @db.Decimal(10, 2)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("compradores")
}

// ─── Pesaje ───────────────────────────────────────────────────────────────────

enum EstadoPesaje {
  OK
  Rechazo
  Pendiente
}

model Pesaje {
  id            Int          @id @default(autoincrement())
  ticket        String       @unique @default(cuid())
  recicladorId  Int
  reciclador    Reciclador   @relation(fields: [recicladorId], references: [id])
  rutaId        Int
  ruta          Ruta         @relation(fields: [rutaId], references: [id])
  horaEntrada   DateTime
  horaSalida    DateTime?
  estado        EstadoPesaje @default(Pendiente)
  observaciones String?
  operadorId    Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  materiales    PesajeMaterial[]

  @@map("pesajes")
}

model PesajeMaterial {
  id          Int      @id @default(autoincrement())
  pesajeId    Int
  pesaje      Pesaje   @relation(fields: [pesajeId], references: [id], onDelete: Cascade)
  materialId  Int
  material    Material @relation(fields: [materialId], references: [id])
  pesoNeto    Decimal  @db.Decimal(10, 3)  // kg
  rechazo     Decimal  @db.Decimal(10, 3)  @default(0)

  @@map("pesaje_materiales")
}

// ─── Balance de Masas ─────────────────────────────────────────────────────────

model BalanceMes {
  id            Int      @id @default(autoincrement())
  anio          Int
  mes           Int      // 1-12
  materialId    Int
  ingresado     Decimal  @db.Decimal(12, 3)
  vendido       Decimal  @db.Decimal(12, 3)
  rechazos      Decimal  @db.Decimal(12, 3)
  ajustes       BalanceAjuste[]
  cerrado       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([anio, mes, materialId])
  @@map("balance_mes")
}

model BalanceAjuste {
  id          Int        @id @default(autoincrement())
  balanceId   Int
  balance     BalanceMes @relation(fields: [balanceId], references: [id])
  cantidad    Decimal    @db.Decimal(10, 3)
  tipo        String     // "entrada" | "salida"
  motivo      String
  operadorId  Int?
  createdAt   DateTime   @default(now())

  @@map("balance_ajustes")
}

// ─── SUI ──────────────────────────────────────────────────────────────────────

enum EstadoSUI {
  borrador
  enviado
  validado
  rechazado
}

model ReporteSUI {
  id              Int        @id @default(autoincrement())
  periodo         String     // "2026-02"
  anio            Int
  mes             Int
  registro13      Json?      // Aprovechamiento
  registro14      Json?      // Ingresos
  estado          EstadoSUI  @default(borrador)
  fechaEnvio      DateTime?
  operadorId      Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([anio, mes])
  @@map("reportes_sui")
}

// ─── PQR ──────────────────────────────────────────────────────────────────────

enum TipoPQR {
  Peticion
  Queja
  Reclamo
}

enum EstadoPQR {
  Recibida
  EnTramite
  Respondida
  Cerrada
}

enum CanalPQR {
  presencial
  email
  telefono
  web
}

model PQR {
  id              Int        @id @default(autoincrement())
  radicado        String     @unique  // PQR-2026-0001
  tipo            TipoPQR
  estado          EstadoPQR  @default(Recibida)
  canal           CanalPQR   @default(web)
  solicitanteId   Int?
  solicitante     Usuario?   @relation("PQRSolicitante", fields: [solicitanteId], references: [id])
  nombreSolicitante String?
  emailSolicitante  String?
  telefonoSolicitante String?
  descripcion     String
  respuesta       String?
  operadorId      Int?
  operador        Usuario?   @relation("PQROperador", fields: [operadorId], references: [id])
  fechaLimite     DateTime
  fechaCierre     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("pqrs")
}
